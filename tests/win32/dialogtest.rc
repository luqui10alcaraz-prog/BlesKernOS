#include <windows.h>
#include "resource_ids.h"

IDD_STAGE7 DIALOG 0, 0, 180, 78
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU | DS_MODALFRAME | DS_SETFONT
CAPTION "BlesKernOS resource dialog"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT       "Name:", -1, 8, 11, 34, 10
    EDITTEXT    IDC_NAME, 45, 8, 122, 14, ES_AUTOHSCROLL
    AUTOCHECKBOX "Remember", IDC_REMEMBER, 45, 29, 70, 12
    DEFPUSHBUTTON "OK", IDOK, 66, 52, 50, 14
END
